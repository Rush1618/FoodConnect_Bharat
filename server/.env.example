# FoodConnect Bharat — Server Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Get yours at: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/foodconnect?retryWrites=true&w=majority

# Server port (default: 5000)
PORT=5000

# JWT secret — use any long random string in production
JWT_SECRET=your_super_secret_jwt_key_here
